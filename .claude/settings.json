{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(uv:*)",
      "Bash(yarn:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(./gradlew:*)"
    ]
  },
  "model": "opusplan",
  "effortLevel": "max",
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  }
}
